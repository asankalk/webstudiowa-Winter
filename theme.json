{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1120px"
    },
    "color": {
      "palette": [
        { "name": "Ink", "slug": "ink", "color": "#14213d" },
        { "name": "Teal", "slug": "teal", "color": "#0c7a7b" },
        { "name": "Gold", "slug": "gold", "color": "#f4b942" },
        { "name": "Coral", "slug": "coral", "color": "#e8674a" },
        { "name": "Surface", "slug": "surface", "color": "#f6f9fc" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Inter, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
          "name": "Inter",
          "slug": "inter"
        }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var:preset|font-family|inter"
    }
  }
}

