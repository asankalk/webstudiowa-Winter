{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1120px"
    },
    "color": {
      "palette": [
        { "name": "Ink", "slug": "ink", "color": "#172033" },
        { "name": "Dodger Blue", "slug": "dodger-blue", "color": "#1e90ff" },
        { "name": "Deep Blue", "slug": "deep-blue", "color": "#0b5fc7" },
        { "name": "Magenta", "slug": "magenta", "color": "#d9005b" },
        { "name": "Orange", "slug": "orange", "color": "#f79400" },
        { "name": "Surface", "slug": "surface", "color": "#f5faff" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
          "name": "System",
          "slug": "system"
        }
      ]
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var:preset|font-family|system"
    }
  }
}
